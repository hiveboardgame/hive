# Shared LEPTOS_* env that cargo-leptos normally sets when running
# `cargo leptos serve`. Required when invoking the bare binary directly.
# Installs to /etc/hive/common.env. Loaded by both blue and green slots.
LEPTOS_BIN_DIR=apis
LEPTOS_LIB_DIR=apis
LEPTOS_OUTPUT_NAME=HiveGame
LEPTOS_SITE_PKG_DIR=pkg
LEPTOS_SITE_ROOT=target/site
LEPTOS_HASH_FILES=true
LEPTOS_HASH_FILE_NAME=hash.txt
LEPTOS_JS_MINIFY=true
